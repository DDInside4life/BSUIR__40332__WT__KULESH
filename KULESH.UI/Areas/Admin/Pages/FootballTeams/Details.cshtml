@page
@model KULESH.UI.Areas.Admin.Pages.FootballTeams.DetailsModel

@{
    ViewData["Title"] = "Team Details";
}

<h1>Team Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Points)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.Points)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Image)
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.FootballTeam.Image))
            {
                <img src="@Model.FootballTeam.Image" alt="@Model.FootballTeam.Name" style="max-width: 300px;" />
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.CategoryId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.CategoryId)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.FootballTeam.Id" class="btn btn-primary">Edit</a>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
</div>