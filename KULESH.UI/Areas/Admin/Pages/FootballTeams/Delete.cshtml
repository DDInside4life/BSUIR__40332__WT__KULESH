@page
@model KULESH.UI.Areas.Admin.Pages.FootballTeams.DeleteModel

@{
    ViewData["Title"] = "Delete Team";
}

<h1>Delete Team</h1>

<h3>Are you sure you want to delete this team?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Points)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.Points)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.Image)
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.FootballTeam.Image))
            {
                <img src="@Model.FootballTeam.Image" alt="@Model.FootballTeam.Name" style="max-width: 200px;" />
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FootballTeam.CategoryId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FootballTeam.CategoryId)
        </dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="FootballTeam.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>