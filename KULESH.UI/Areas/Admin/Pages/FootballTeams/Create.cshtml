@page
@model KULESH.UI.Areas.Admin.Pages.FootballTeams.CreateModel

@{
    ViewData["Title"] = "Create Team";
}

<h1>Create New Team</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="FootballTeam.Name" class="control-label"></label>
                <input asp-for="FootballTeam.Name" class="form-control" />
                <span asp-validation-for="FootballTeam.Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FootballTeam.Description" class="control-label"></label>
                <textarea asp-for="FootballTeam.Description" class="form-control"></textarea>
                <span asp-validation-for="FootballTeam.Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FootballTeam.Points" class="control-label"></label>
                <input asp-for="FootballTeam.Points" class="form-control" />
                <span asp-validation-for="FootballTeam.Points" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FootballTeam.CategoryId" class="control-label"></label>
                <select asp-for="FootballTeam.CategoryId" asp-items="Model.Categories" class="form-control">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="FootballTeam.CategoryId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ImageFile" class="control-label"></label>
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}