@{
    var controller = ViewData["Controller"]!.ToString();
    var area = ViewData["Area"]!.ToString();
}
<a class="navbar-brand @(controller == "home" ? "active" : "")"
   asp-controller="home"
   asp-action="index">KULESH</a>
<div class="navbar-nav">
    <a class="nav-item nav-link 
    @(controller == "home" ? "active" : "")"
       asp-controller="home" 
       asp-action="index">Лб 1</a>
    <a class="nav-item nav-link
    @(controller == "product" ? "active" : "")"
       asp-controller="product" 
       asp-action="index">Каталог</a>
    <a class="nav-item nav-link 
    @(area == "admin" ? "active" : "")"
       asp-area="admin" 
       asp-page="/index">Администрирование</a>
</div>
